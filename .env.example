# For local development with PostgreSQL:
DATABASE_URL="postgresql://user:password@localhost:5432/statcalendar?schema=public"

# For Railway: this will be set automatically when you add a Postgres plugin
# DATABASE_URL="postgresql://..."

# JWT secret - change this to a random string
JWT_SECRET="change-me-to-a-long-random-secret-string-at-least-32-chars"
